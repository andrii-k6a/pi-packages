#!/usr/bin/env bash
# Start SearXNG in a podman/docker container with a local config.
# Usage: scripts/start-searxng [--port PORT] [--detach]

set -euo pipefail

HOST="${SEARXNG_HOST:-127.0.0.1}"
PORT="${SEARXNG_PORT:-8888}"
CONTAINER_PORT=8080
DETACH=false
CONFIG_DIR="${SEARXNG_CONFIG_DIR:-}"
NAME="${SEARXNG_CONTAINER_NAME:-searxng}"
IMAGE="${SEARXNG_IMAGE:-docker.io/searxng/searxng:latest}"

usage() {
  cat <<'EOF'
Usage: start-searxng [OPTIONS]

Start a local SearXNG metasearch engine in podman or docker.

Options:
  --host HOST       Host interface to bind (default: $SEARXNG_HOST or 127.0.0.1)
  --port PORT       Host port to bind (default: $SEARXNG_PORT or 8888)
  --detach, -d      Run in background (default: foreground)
  --config DIR      Use config directory (default: $SEARXNG_CONFIG_DIR or ~/.cache/web-discovery)
  --name NAME       Container name (default: searxng)
  --help, -h        Show this help

Environment:
  SEARXNG_URL             Used by scripts/searx; not needed here unless calling clients
  SEARXNG_HOST            Default host interface
  SEARXNG_PORT            Default host port
  SEARXNG_CONFIG_DIR      Default config directory
  SEARXNG_CONTAINER_NAME  Default container name
  SEARXNG_IMAGE           Container image

Examples:
  scripts/start-searxng --detach
  scripts/start-searxng --port 9999 -d
  scripts/start-searxng --host 0.0.0.0 --port 9999 -d  # expose beyond localhost

Stop with: podman stop searxng  # or: docker stop searxng
EOF
}

require_value() {
  local option="$1"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == -* ]]; then
    echo "Error: $option requires a value" >&2
    usage >&2
    exit 2
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      require_value "$1" "${2:-}"
      HOST="$2"
      shift 2
      ;;
    --port)
      require_value "$1" "${2:-}"
      PORT="$2"
      shift 2
      ;;
    --detach|-d)
      DETACH=true
      shift
      ;;
    --config)
      require_value "$1" "${2:-}"
      CONFIG_DIR="$2"
      shift 2
      ;;
    --name)
      require_value "$1" "${2:-}"
      NAME="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ -z "$CONFIG_DIR" ]]; then
  cache_root="${XDG_CACHE_HOME:-$HOME/.cache}"
  CONFIG_DIR="$cache_root/web-discovery"
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "Error: curl is required" >&2
  exit 1
fi

if command -v podman >/dev/null 2>&1; then
  RUNTIME="podman"
elif command -v docker >/dev/null 2>&1; then
  RUNTIME="docker"
else
  echo "Error: neither podman nor docker was found in PATH" >&2
  exit 1
fi

echo "Using container runtime: $RUNTIME"

container_running() {
  "$RUNTIME" ps --format '{{.Names}}' | grep -Fxq "$NAME"
}

container_exists() {
  "$RUNTIME" ps -a --format '{{.Names}}' | grep -Fxq "$NAME"
}

wait_ready() {
  echo "Waiting for SearXNG to be ready on http://127.0.0.1:$PORT ..."
  for _ in {1..30}; do
    if curl -sf "http://127.0.0.1:$PORT/" >/dev/null 2>&1; then
      echo "✓ SearXNG is ready"
      echo "Access:   http://127.0.0.1:$PORT"
      echo "JSON API: http://127.0.0.1:$PORT/search?q=test&format=json"
      return 0
    fi
    sleep 1
  done

  echo "Warning: service did not respond within 30 seconds" >&2
  echo "Check logs with: $RUNTIME logs $NAME" >&2
  return 1
}

if container_running; then
  echo "SearXNG container '$NAME' is already running."
  wait_ready
  echo "Stop with: $RUNTIME stop $NAME"
  exit 0
fi

if container_exists; then
  echo "Removing stopped container '$NAME'."
  "$RUNTIME" rm "$NAME" >/dev/null
fi

mkdir -p "$CONFIG_DIR"

if [[ ! -f "$CONFIG_DIR/settings.yml" ]]; then
  cat > "$CONFIG_DIR/settings.yml" <<'EOF'
# Minimal local SearXNG configuration for web search.
# See https://docs.searxng.org/admin/settings/settings.html

use_default_settings: true

search:
  formats:
    - html
    - json

server:
  secret_key: "local-web-discovery-change-me-if-public"
  bind_address: "0.0.0.0"
  port: 8080
  limiter: false
  public_instance: false
EOF
  echo "Created config: $CONFIG_DIR/settings.yml"
else
  echo "Using config: $CONFIG_DIR/settings.yml"
fi

volume_spec="$CONFIG_DIR:/etc/searxng"
if [[ "$RUNTIME" == "podman" ]]; then
  volume_spec="$volume_spec:Z"
fi

RUN_ARGS=(
  run
  --rm
  --name "$NAME"
  -p "$HOST:$PORT:$CONTAINER_PORT"
  -v "$volume_spec"
)

if [[ "$DETACH" == true ]]; then
  RUN_ARGS+=(-d)
fi

echo "Starting SearXNG on $HOST:$PORT ..."
if [[ "$DETACH" != true ]]; then
  echo "Running in foreground. Press Ctrl+C to stop."
fi

"$RUNTIME" "${RUN_ARGS[@]}" "$IMAGE"

if [[ "$DETACH" == true ]]; then
  wait_ready
  echo "Stop with: $RUNTIME stop $NAME"
fi
