#!/usr/bin/env bash
# SearXNG search helper for agent skills.
# Usage: scripts/searx <query> [--category <cat>] [--limit <n>] [--engines <engine>] [--json]

set -euo pipefail

BASE_URL="${SEARXNG_URL:-http://localhost:${SEARXNG_PORT:-8888}}"
CATEGORY="general"
LIMIT="10"
ENGINES=""
RAW_JSON=false
QUERY_PARTS=()

usage() {
  cat <<'EOF'
Usage: searx [OPTIONS] <query>

Search a local SearXNG instance and print compact results.

Options:
  -c, --category CATEGORY   Search category (default: general)
  -e, --engines ENGINES     Comma-separated engine list, e.g. npm,crates.io
  -l, --limit N             Number of results to display (default: 10)
      --url URL             SearXNG base URL (default: $SEARXNG_URL or http://localhost:8888)
      --json                Print JSON output; respects --limit by slicing .results when jq is available
  -h, --help                Show this help

Examples:
  searx --category it "agent skills web search"
  searx --category cargo --limit 5 tokio
  searx --category packages --engines npm express
EOF
}

require_value() {
  local option="$1"
  local value="${2:-}"

  if [[ -z "$value" || "$value" == -* ]]; then
    echo "Error: $option requires a value" >&2
    usage >&2
    exit 2
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c|--category)
      require_value "$1" "${2:-}"
      CATEGORY="$2"
      shift 2
      ;;
    -e|--engines)
      require_value "$1" "${2:-}"
      ENGINES="$2"
      shift 2
      ;;
    -l|--limit)
      require_value "$1" "${2:-}"
      LIMIT="$2"
      shift 2
      ;;
    --url)
      require_value "$1" "${2:-}"
      BASE_URL="$2"
      shift 2
      ;;
    --json)
      RAW_JSON=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      QUERY_PARTS+=("$@")
      break
      ;;
    -* )
      echo "Unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      QUERY_PARTS+=("$1")
      shift
      ;;
  esac
done

QUERY="${QUERY_PARTS[*]}"
if [[ -z "${QUERY// }" ]]; then
  usage >&2
  exit 2
fi

if ! [[ "$LIMIT" =~ ^[0-9]+$ ]]; then
  echo "Error: --limit must be a non-negative integer" >&2
  exit 2
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "Error: curl is required" >&2
  exit 1
fi

search_url="${BASE_URL%/}/search"

CURL_ARGS=(
  -fsS
  -G "$search_url"
  --data-urlencode "q=$QUERY"
  --data-urlencode "format=json"
)

if [[ "$CATEGORY" != "general" ]]; then
  CURL_ARGS+=(--data-urlencode "categories=$CATEGORY")
fi

if [[ -n "$ENGINES" ]]; then
  CURL_ARGS+=(--data-urlencode "engines=$ENGINES")
fi

if ! response="$(curl "${CURL_ARGS[@]}" 2>/dev/null)"; then
  echo "Error: could not reach SearXNG at ${BASE_URL%/}" >&2
  echo "Start it with: scripts/start-searxng --detach" >&2
  exit 1
fi

if [[ "$RAW_JSON" == true ]]; then
  if command -v jq >/dev/null 2>&1; then
    printf '%s\n' "$response" | jq --argjson limit "$LIMIT" '.results = ((.results // [])[0:$limit])'
  else
    echo "Warning: jq not found; printing unsliced JSON because --limit cannot be applied." >&2
    printf '%s\n' "$response"
  fi
  exit 0
fi

if command -v jq >/dev/null 2>&1; then
  USE_COLOR=false
  if [[ -t 1 ]]; then
    USE_COLOR=true
  fi

  printf '%s\n' "$response" | jq -r --argjson limit "$LIMIT" --argjson color "$USE_COLOR" '
    def colorize($code; $text): if $color then "\u001b[" + $code + "m" + $text + "\u001b[0m" else $text end;

    if (.results // []) | length == 0 then
      "No results found."
      + (if (.unresponsive_engines // []) | length > 0 then "\nUnresponsive engines: " + (.unresponsive_engines | join(", ")) else "" end)
      + (if (.suggestions // []) | length > 0 then "\nSuggestions: " + (.suggestions | join(", ")) else "" end)
    else
      (.results[0:$limit][] |
        colorize("32"; (.title // "Untitled")) + "\n" +
        "  URL: " + colorize("34"; (.url // "")) + "\n" +
        "  Engines: " + ((.engines // []) | join(", ")) +
        (if (.content // "") != "" then "\n  " + .content else "" end) +
        "\n"
      ),
      colorize("33"; "Showing " + (([.results[0:$limit][]] | length) | tostring) + " of " + ((.number_of_results // (.results | length)) | tostring) + " results")
    end
  '
else
  echo "jq not found; printing unsliced JSON response. Install jq for formatted output and --limit support." >&2
  printf '%s\n' "$response"
fi
